{
  "name": "reconexão-essencial",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend": "cd ../reconexao-essencial-backend/backend_fastapi && .\\.venv\\Scripts\\python.exe -m uvicorn app.main:create_app --factory --reload --port 8000",
    "build": "vite build",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:bundle": "npm run android:sync && cd android && .\\gradlew.bat bundleRelease",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios",
    "screenshots:ios": "node scripts/capture-ios-screenshots.mjs",
    "screenshots:play": "node scripts/capture-play-store-screenshots.mjs",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@google/genai": "^1.40.0",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "playwright-core": "^1.60.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
